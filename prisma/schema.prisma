generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Model {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  provider    String
  description String?
  parameters  Float
  vramQ4      Float?
  vramQ8      Float?
  ramMin      Float?
  cpuRec      String?
  hfUrl       String?
  downloads   Int      @default(0)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
